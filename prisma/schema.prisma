generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candle {
  id        String   @id @default(uuid())
  symbol    String
  interval  String
  price     Float
  timestamp DateTime

  @@index([symbol, interval, timestamp])
}

model Indicator {
  id                 String   @id @default(uuid())
  symbol             String
  ema50              Float
  trend              String
  priceChangePoint   Float
  priceChangePercent Float
  timestamp          DateTime

  @@unique([symbol, timestamp], name: "symbol_timestamp")
}